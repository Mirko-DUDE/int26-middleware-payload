# ── Configurazione minima per avviare il dev server in locale ───────────────
# Copia questo file in .env e compila i valori mancanti.
# Le variabili GCP, Furious e Sentry non sono necessarie per avviare
# il server senza testare il flusso completo.

# ── Database ────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/int26_dev

# ── PayloadCMS ──────────────────────────────────────────
PAYLOAD_SECRET=dev-secret-non-usare-in-produzione
SERVER_URL=http://localhost:3000

# ── GCP — Worker endpoint ───────────────────────────────
WORKER_BASE_URL=http://localhost:3000

# Secret per autenticazione worker in locale (NODE_ENV != production)
# Genera con: openssl rand -hex 32
WORKER_DEV_SECRET=dev-worker-secret

NODE_ENV=development

# ── Variabili non necessarie in locale ──────────────────
# Le seguenti variabili sono richieste solo per testare il flusso completo:
#
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# ALLOWED_EMAIL_DOMAIN=
# BOOTSTRAP_ADMIN_EMAIL=
# SISTEMA_EMAIL=
# GOOGLE_SERVICE_ACCOUNT_KEY_JSON=
# GMAIL_DELEGATED_USER=
# GMAIL_SENDER_ADDRESS=
# GCP_PROJECT_ID=
# GCP_LOCATION=
# CLOUD_TASKS_QUEUE_ABSENCES=
# CLOUD_TASKS_QUEUE_INVOICES=
# CLOUD_TASKS_SERVICE_ACCOUNT=
# FURIOUS_USERNAME=
# FURIOUS_PASSWORD=
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=
