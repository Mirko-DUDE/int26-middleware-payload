  ],
  access: { update: ({ req: { user } }) => user?.role === 'admin' },
},
{
  name: 'status',
  type: 'select',
  defaultValue: 'invited',
  saveToJWT: true,  // ← NON RIMUOVERE MAI — blocca suspended senza DB lookup
  options: [
    { label: 'Invitato',  value: 'invited' },
    { label: 'Attivo',    value: 'active' },
    { label: 'Sospeso',   value: 'suspended' },
  ],
  access: { update: ({ req: { user } }) => user?.role === 'admin' },
},

// ❌ SBAGLIATO — status non nel JWT
{
  name: 'status',
  type: 'select',
  saveToJWT: false, // ← richiede DB lookup per verificare la sospensione
}
