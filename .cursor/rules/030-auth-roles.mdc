## PATTERN: Gmail API mailer

```typescript
// ✅ CORRETTO — src/services/mailer.ts
import { google } from 'googleapis'

export async function sendMail({ to, subject, html }) {
  const key = JSON.parse(process.env.GOOGLE_SERVICE_ACCOUNT_KEY_JSON!)

  const auth = new google.auth.JWT({
    email: key.client_email,
    key: key.private_key,
    scopes: ['https://www.googleapis.com/auth/gmail.send'],
    subject: process.env.GMAIL_DELEGATED_USER, // impersona noreply@azienda.it
  })

  const gmail = google.gmail({ version: 'v1', auth })
  // ... encode RFC 2822 e invia
}

// ❌ SBAGLIATO — usa servizi email esterni
