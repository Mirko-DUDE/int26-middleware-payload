## PATTERN: Hook invio mail di invito

```typescript
// ✅ CORRETTO — src/collections/hooks/sendInviteEmailHook.ts
export const sendInviteEmailHook: CollectionAfterChangeHook = async ({ doc, operation }) => {
  if (operation !== 'create') return doc  // solo alla creazione
  if (doc.role === 'sistema') return doc  // service account non riceve inviti

  await sendMail({
    to: doc.email,
    subject: 'Sei stato invitato ad accedere al sistema',
    html: `...link login Google...`,
  })

  return doc
}

// ❌ SBAGLIATO — invia mail anche agli update del record
export const sendInviteEmailHook: CollectionAfterChangeHook = async ({ doc }) => {
  // senza controllo su operation — si invia mail a ogni modifica del record
  await sendMail({ to: doc.email, ... })
}
```

