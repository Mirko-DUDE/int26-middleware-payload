## PATTERN: canRead / canWrite con controllo status

```typescript
// ✅ CORRETTO — controllo status trasversale in permissions.ts
export function canRead(resource: Resource) {
  return ({ req }: { req: PayloadRequest }): boolean => {
    const user = req.user
    if (!user) return false
    if (user.status === 'suspended') return false  // ← blocco trasversale
    return activeProvider.canRead(user.role as UserRole, resource)
  }
}

// ❌ SBAGLIATO — controlla solo il ruolo, ignora lo status
export function canRead(resource: Resource) {
  return ({ req }: { req: PayloadRequest }): boolean => {
    const role = req.user?.role as UserRole
    return activeProvider.canRead(role, resource)
  }
}
```

