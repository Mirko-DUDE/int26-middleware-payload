# ── Database ────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/int26

# ── PayloadCMS ──────────────────────────────────────────
PAYLOAD_SECRET=cambia-con-stringa-casuale-lunga
SERVER_URL=http://localhost:3000

# ── Google OAuth2 SSO ───────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
ALLOWED_EMAIL_DOMAIN=tuaazienda.com

# ── Bootstrap primo avvio ───────────────────────────────
BOOTSTRAP_ADMIN_EMAIL=admin@tuaazienda.com
SISTEMA_EMAIL=sistema@tuaazienda.com

# ── Gmail API (domain-wide delegation) ──────────────────
GOOGLE_SERVICE_ACCOUNT_KEY_JSON={"type":"service_account",...}
GMAIL_DELEGATED_USER=mittente@tuaazienda.com
GMAIL_SENDER_ADDRESS=mittente@tuaazienda.com
# GMAIL_DELEGATED_USER e GMAIL_SENDER_ADDRESS devono essere uguali

# ── GCP — progetto e regione ────────────────────────────
GCP_PROJECT_ID=nome-progetto-gcp
# Usato da src/lib/gcp/tasks.ts come GCP_LOCATION (default: europe-west1)
GCP_LOCATION=europe-west8

# ── GCP — Cloud Tasks code ──────────────────────────────
CLOUD_TASKS_QUEUE_ABSENCES=queue-absences
CLOUD_TASKS_QUEUE_INVOICES=queue-invoices

# ── GCP — Worker endpoint ───────────────────────────────
# URL base del server raggiungibile da Cloud Tasks
# In locale: http://localhost:3000
# In staging/prod: URL del servizio Cloud Run
WORKER_BASE_URL=http://localhost:3000

# Service account email autorizzato a chiamare il worker
# In locale: non usato (autenticazione via WORKER_DEV_SECRET)
CLOUD_TASKS_SERVICE_ACCOUNT=sa-name@progetto.iam.gserviceaccount.com

# Secret per autenticazione worker in locale (NODE_ENV != production)
# Genera con: openssl rand -hex 32
WORKER_DEV_SECRET=

# ── Furious API ─────────────────────────────────────────
# Nota: il codice usa FURIOUS_USERNAME (non FURIOUS_EMAIL)
FURIOUS_USERNAME=
FURIOUS_PASSWORD=

# ── Sentry (opzionale in locale) ────────────────────────
SENTRY_DSN=
# staging | production
SENTRY_ENVIRONMENT=staging

# ── Variabili presenti nel codice ma non richieste in locale ────────────────
# SISTEMA_JWT — JWT del service account sistema; generato con
#   src/scripts/generate-sistema-jwt.ts. In produzione montato da GCP Secret Manager.
# SISTEMA_JWT=
#
# PAYLOAD_INTERNAL_URL — URL interno per chiamate worker→Payload.
#   Non ancora usato nel codice attivo; riservato per sviluppi futuri.
# PAYLOAD_INTERNAL_URL=http://localhost:3000
