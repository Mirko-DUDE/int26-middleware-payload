# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/int26-middleware-payload

# ─── PayloadCMS ───────────────────────────────────────────────────────────────
PAYLOAD_SECRET=your-secret-here

# ─── Google OAuth2 (A3) ───────────────────────────────────────────────────────
# Credenziali OAuth2 dalla Google Cloud Console (tipo applicazione: Internal)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# URL pubblico del server (senza trailing slash)
# Usato per: callback OAuth2, link nelle mail di invito
PAYLOAD_PUBLIC_SERVER_URL=https://middleware.azienda.it

# Dominio email aziendale — solo utenti @ALLOWED_EMAIL_DOMAIN possono accedere
ALLOWED_EMAIL_DOMAIN=azienda.it

# Email del primo admin — creato automaticamente al primo login Google
BOOTSTRAP_ADMIN_EMAIL=admin@azienda.it

# ─── Service Account Sistema (A3) ─────────────────────────────────────────────
# Email del service account usato dai worker interni
SISTEMA_EMAIL=sistema@azienda.it

# JWT del service account sistema — generato con src/scripts/generate-sistema-jwt.ts
# In produzione: montato da GCP Secret Manager
SISTEMA_JWT=

# URL interno per chiamate worker→Payload (può essere localhost in Cloud Run)
PAYLOAD_INTERNAL_URL=http://localhost:3000

# ─── Gmail API (A3) ───────────────────────────────────────────────────────────
# Indirizzo mittente per le mail di invito
GMAIL_SENDER_ADDRESS=noreply@azienda.it

# Account impersonato dalla domain-wide delegation del Service Account
GMAIL_DELEGATED_USER=noreply@azienda.it

# Chiave JSON del Service Account GCP (da GCP Secret Manager in produzione)
# Formato: '{"type":"service_account","project_id":"...","private_key":"...","client_email":"...",...}'
GOOGLE_SERVICE_ACCOUNT_KEY_JSON=

# ─── GCP Infrastructure (A5) ──────────────────────────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id
WORKER_BASE_URL=https://middleware.azienda.it
CLOUD_TASKS_QUEUE_ABSENCES=queue-absences-prod
CLOUD_TASKS_QUEUE_INVOICES=queue-invoices-prod
